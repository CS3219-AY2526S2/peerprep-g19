# MongoDB connection string (defaults to local if unset)
QN_SERVICE_CLOUD_URI=mongodb://localhost:27017

# Firebase Admin SDK credentials (for admin auth on write endpoints)
# Option 1: Full service account JSON string
# FIREBASE_SERVICE_KEY={"type":"service_account","project_id":"...","client_email":"...","private_key":"..."}

# Option 2: Individual env vars
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
