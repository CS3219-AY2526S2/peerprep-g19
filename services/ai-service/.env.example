# AI Service Configuration
PORT=5050

# Google Gemini API
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here
GOOGLE_GEMINI_MODEL=gemini-1.5-flash
GOOGLE_GEMINI_TEMPERATURE=0.2
GOOGLE_GEMINI_MAX_TOKENS=700

# Firebase Authentication (same credentials as other services)
# Option 1: Full service account JSON string
# FIREBASE_SERVICE_KEY={"type":"service_account",...}
# Option 2: Individual env vars
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Question Service URL (for fetching question context)
QUESTION_SERVICE_URL=http://localhost:8000
QUESTION_FETCH_TIMEOUT_MS=5000

# Code size limits
MAX_CODE_CHARS=20000
