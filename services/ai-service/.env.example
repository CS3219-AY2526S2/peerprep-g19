# AI Service Configuration

# Port the service runs on
PORT=5000

# Google Gemini API
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here
GOOGLE_GEMINI_MODEL=gemini-1.5-flash
GOOGLE_GEMINI_TEMPERATURE=0.2
GOOGLE_GEMINI_MAX_TOKENS=700

# Firebase Authentication
# Option 1: Path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./config/service_key.json
# Option 2: Or provide as base64-encoded JSON string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Question Service URL (for fetching question context)
QUESTION_SERVICE_URL=http://localhost:8000
QUESTION_FETCH_TIMEOUT_MS=5000

# Code size limits
MAX_CODE_CHARS=20000

# Testing flags
AI_MOCK_MODE=false
E2E_AUTH_BYPASS=false
